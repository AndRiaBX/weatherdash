<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WeatherDash</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; }
    .box { background: rgba(255,255,255,.12); backdrop-filter: blur(12px); border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 480px; text-align: center; }
    h1 { font-size: 2rem; font-weight: 700; margin-bottom: .25rem; }
    p.sub { opacity: .8; margin-bottom: 1.5rem; font-size: .95rem; }
    form { display: flex; gap: .5rem; }
    input[type="text"] { flex: 1; padding: .7rem 1rem; border: none; border-radius: 12px; font-size: 1rem; outline: none; }
    button { padding: .7rem 1.25rem; background: #fff; color: #667eea; border: none; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: transform .1s; }
    button:hover { transform: scale(1.02); }
    .error { background: rgba(255,0,0,.2); padding: .5rem 1rem; border-radius: 10px; margin-bottom: 1rem; font-size: .9rem; }
    .examples { margin-top: 1.5rem; font-size: .85rem; opacity: .7; }
    .examples a { color: #fff; text-decoration: underline; }
    footer { margin-top: 1.5rem; font-size: .8rem; opacity: .5; }
  </style>
</head>
<body>
  <div class="box">
    <h1>🌤 WeatherDash</h1>
    <p class="sub">Check the forecast for any city</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/">
      <input type="text" name="city" placeholder="Enter a city name..." required>
      <button type="submit">Search</button>
    </form>
    <div class="examples">
      Try: <a href="/weather?city=Tbilisi">Tbilisi</a>, <a href="/weather?city=Tokyo">Tokyo</a>, <a href="/weather?city=London">London</a>
    </div>
  </div>
  <footer>Powered by <a href="https://open-meteo.com" style="color:#fff;">Open-Meteo</a></footer>
</body>
</html>
