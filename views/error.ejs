<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — WeatherDash</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; }
    .box { background: rgba(255,255,255,.12); backdrop-filter: blur(12px); border-radius: 20px; padding: 2rem; width: 100%; max-width: 480px; text-align: center; }
    h1 { font-size: 1.5rem; margin-bottom: .5rem; }
    p { opacity: .8; margin-bottom: 1.5rem; }
    a { color: #fff; }
  </style>
</head>
<body>
  <div class="box">
    <h1>⚠️ Error</h1>
    <p><%= message %></p>
    <a href="/">← Try again</a>
  </div>
</body>
</html>
